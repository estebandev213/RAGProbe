GROQ_API_KEY=
DEMO_MODE=true
DATABASE_PATH=./data/ragprobe.db
GROQ_GENERATION_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# Optional but recommended: an independent judge. When set, grading runs on
# Gemini (free tier at aistudio.google.com) instead of the model that wrote
# the answers — removing self-preference bias from the scores.
GEMINI_API_KEY=
GEMINI_JUDGE_MODEL=gemini-3.5-flash
